# Medici - Environment Variables Template
# Copy this to .env and fill in your actual values

# DeepSeek API Key (get from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemma API Key (get from Google AI Studio)
GEMMA_API_KEY=your_gemma_api_key_here

# WhatsApp Cloud API Verify Token (you set this when configuring webhook)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# Boss's Father Phone Number (for order confirmation)
BOSS_FATHER_PHONE=+919999999999

# WhatsApp Business Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# WhatsApp Access Token (from Meta Developer Portal)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
